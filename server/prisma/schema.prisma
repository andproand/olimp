generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Olympiad {
  id            Int       @id @default(autoincrement())
  name          String
  organizer     String?
  ministryLevel Int?      // 1, 2, 3 or null
  website       String?
  login         String?   // New
  password      String?   // New
  priority      String    @default("Medium") // Deprecated, moving to Profile. Kept for migration safety if needed, or remove. Let's remove and migrate data if possible, or keep for now. 
  // Actually, user wants it on Profile. Let's remove from here in next step or keep as default? 
  // Better to remove and rely on Profile priority.
  description   String?
  contacts      String?
  profiles      Profile[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Profile {
  id           Int       @id @default(autoincrement())
  subject      String
  level        Int?
  description  String?
  priority     String    @default("Medium") // Moved from Olympiad
  academicYear String    @default("2024/2025") // New field
  olympiadId   Int
  olympiad     Olympiad  @relation(fields: [olympiadId], references: [id], onDelete: Cascade)
  stages       Stage[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique // e.g. "userName"
  value String
}

model Stage {
  id             Int       @id @default(autoincrement())
  name           String    // e.g. "Qualifying Round", "Final"
  type           String    // Online, Offline
  time           String?   // e.g. "10:00"
  startDate      DateTime?
  endDate        DateTime?
  regDeadline    DateTime?
  attempts       Int       @default(1)
  profileId      Int
  profile        Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  results        Result[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Result {
  id           Int      @id @default(autoincrement())
  userScore    Float?
  passingScore Float?
  status       String   // Winner, Prize-winner, Participant, Failed, Waiting
  diplomaLink  String?
  stageId      Int
  stage        Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
